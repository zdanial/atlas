# Butterfly — Environment Variables
# Copy this file to .env and fill in the values.

# PostgreSQL connection (required for Mode B — local server)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/butterfly

# AI Provider API keys (optional — enables AI features)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Frontend API URL (set for Mode B — local server)
# PUBLIC_API_URL=http://localhost:3001

# Supabase (Mode C — cloud)
# PUBLIC_SUPABASE_URL=
# PUBLIC_SUPABASE_ANON_KEY=
